generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  phone     String?
  address   String?
  role      Role      @default(USER)
  // রিলেশন নাম আপডেট করা হয়েছে
  bookings  Booking[] 
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Bike {
  id           Int       @id @default(autoincrement())
  name         String
  description  String
  pricePerHour Float    
  isAvailable  Boolean   @default(true)
  brand        String
  model        String
  cc           Int
  // রিলেশন নাম আপডেট করা হয়েছে
  bookings  Booking[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Rental এর বদলে এখন Booking
model Booking {
  id         Int       @id @default(autoincrement())
  userId     Int
  bikeId     Int
  startTime  DateTime  @default(now())
  returnTime DateTime?
  totalCost  Float     @default(0)
  isReturned Boolean   @default(false)

  user User @relation(fields: [userId], references: [id])
  bike Bike @relation(fields: [bikeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([bikeId])
  // ডাটাবেজে টেবিলের নাম bookings দেখাবে
  @@map("bookings") 
}